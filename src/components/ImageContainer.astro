---
const { src, alt, caption } = Astro.props;
---

<div
    class="mt-6 mb-6 border border-gray-200 dark:border-zinc-700 bg-gray-100 dark:bg-zinc-800 pt-2 pl-2 pr-2 rounded-lg transition-colors duration-300"
>
    <img src={src} alt={alt} class="w-full h-auto rounded-md" />
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 mb-2 text-center">
        {caption}
    </p>
</div>
