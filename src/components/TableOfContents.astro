<aside
    class="toc-container bg-gray-50 dark:bg-zinc-800 p-4 rounded-lg border border-gray-200 dark:border-zinc-700 transition-colors duration-300"
>
    <h4
        class="font-bold text-gray-900 dark:text-gray-100 mb-2 italic"
        style="margin-top:0;"
    >
        Contents
    </h4>
    <ul
        id="toc-list"
        class="space-y-1 text-sm text-custom-orange-700 dark:text-custom-orange-400"
    >
    </ul>
</aside>

<script>
    // ページ内のすべての h3 タグを取得
    const headings = document.querySelectorAll("main h3");
    const tocList = document.getElementById("toc-list");

    headings.forEach((heading, index) => {
        // 1. 各h3にIDを振る（リンク用）
        const id = heading.id || `heading-${index}`;
        heading.id = id;

        // 2. 目次用のリストアイテムを作成
        const li = document.createElement("li");
        const a = document.createElement("a");
        a.href = `#${id}`;
        a.textContent = heading.textContent;
        a.className = "hover:underline";

        li.appendChild(a);
        tocList?.appendChild(li);
    });
</script>
